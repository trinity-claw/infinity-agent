OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

ROUTER_MODEL=openai/gpt-4o-mini
KNOWLEDGE_MODEL=google/gemini-2.5-flash
SUPPORT_MODEL=anthropic/claude-sonnet-4.5
SENTIMENT_MODEL=openai/gpt-4o-mini
GUARDRAIL_MODEL=openai/gpt-4o-mini

EMBEDDING_MODEL=openai/text-embedding-3-small

BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search

CHROMA_PERSIST_DIR=./data/chroma_db
SQLITE_DB_PATH=./data/langgraph.sqlite

APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:5173

ENABLE_GUARDRAILS=true
ENABLE_STREAMING=true
ENABLE_SENTIMENT_AGENT=true

WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE=main
WHATSAPP_OPERATOR_NUMBER=

AUTHENTICATION_API_KEY=change_me_in_env
