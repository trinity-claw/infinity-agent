# =============================================================================
# Infinity Agent — Environment Variables
# =============================================================================

# OpenRouter API Key (required)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM Models (via OpenRouter)
ROUTER_MODEL=openai/gpt-4o-mini
KNOWLEDGE_MODEL=openai/gpt-4o-mini
SUPPORT_MODEL=anthropic/claude-sonnet-4.5
SENTIMENT_MODEL=openai/gpt-4o-mini
GUARDRAIL_MODEL=openai/gpt-4o-mini

# Embedding Model
EMBEDDING_MODEL=openai/text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Feature Flags
ENABLE_GUARDRAILS=true
ENABLE_STREAMING=true
ENABLE_SENTIMENT_AGENT=true
